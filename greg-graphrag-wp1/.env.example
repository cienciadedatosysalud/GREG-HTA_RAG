# =========================================================
# 1. INFRASTRUCTURE (Docker Networking)
# =========================================================

# If Ollama is running on the host, use: http://host.docker.internal:11434
OLLAMA_HOST=http://host.docker.internal:11434

# API endpoint for the chatbot
PUBLIC_API_URL=http://localhost:8000

# Connection to FalkorDB (assuming the service is named ‘falkordb’ in compose)
# If you run Falkor outside of Docker, use 'host.docker.internal'
FALKOR_HOST=falkordb
FALKOR_PORT=6379
GRAPH_NAME=rwe_knowledge_graph
GRAPH_CONVERSATIONS=chat_history_graph

# =========================================================
# 2. AI MODELS AND CONFIGURATION
# =========================================================

MODEL_EXTRACTOR=gemma4:26b
MODEL_CHAT=llama3.3:70b
MODEL_QUERY_REFINER=llama3.1:8b
MODEL_EMBEDDING=nomic-embed-text
EMBEDDING_DIM=768


TEMPERATURE_EXTRACTOR=0.0
TEMPERATURE_METADATA=0.0
NUM_CTX=16384
REPEAT_PENALTY=1.1

# =========================================================
# 3. PATHS INSIDE THE CONTAINER (Mount Points)
# =========================================================

# These paths must match the WORKDIR defined in the Dockerfile

LANCEDB_PATH=/app/data/lancedb
RAW_DATA_PATH=/app/data/raw
PROCESSED_DATA_PATH=/app/data/processed
MANIFEST_PATH=/app/data/metadata_manifest.jsonl


# =========================================================
# 4. INGESTION PARAMETERS.
# =========================================================

MIN_PARENT_SIZE=7000
MAX_PARENT_SIZE=13000

CHILD_SIZE=1000
CHILD_OVERLAP=2

# =========================================================
# 5. LOGGING
# =========================================================

LOG_LEVEL=INFO